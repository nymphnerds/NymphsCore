<Window x:Class="NymphsCoreManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=""
        Icon="/AppAssets/nsw.ico"
        Width="1060"
        Height="620"
        MinWidth="240"
        MinHeight="390"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#081112"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="Window_SizeChanged">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#081112" />
    <SolidColorBrush x:Key="PanelBrush" Color="#0B1718" />
    <SolidColorBrush x:Key="PanelEdgeBrush" Color="#1B3536" />
    <SolidColorBrush x:Key="MutedBrush" Color="#9BB9B4" />
    <SolidColorBrush x:Key="BodyBrush" Color="#E4F2EF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#29E6DA" />
    <SolidColorBrush x:Key="LimeBrush" Color="#97DF48" />
    <Thickness x:Key="HomeSectionSpacing">0,0,0,30</Thickness>
    <Thickness x:Key="HomeCardsTopSpacing">0,14,0,0</Thickness>
    <Thickness x:Key="HomeOverviewCardTopSpacing">0,14,0,0</Thickness>
    <Thickness x:Key="HomeModuleSectionSpacing">0,0,0,12</Thickness>

    <Style TargetType="TextBlock" x:Key="MonoLabelStyle">
      <Setter Property="FontFamily" Value="Cascadia Mono" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="TextBlock" x:Key="PageSubtitleStyle">
      <Setter Property="FontFamily" Value="Bahnschrift Light" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="#23E7DB" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style TargetType="TextBlock" x:Key="AccentTextStyle">
      <Setter Property="FontFamily" Value="Bahnschrift Light" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="#23E7DB" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style TargetType="TextBlock" x:Key="PageTitleStyle">
      <Setter Property="FontFamily" Value="Bahnschrift" />
      <Setter Property="FontStretch" Value="Condensed" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="28" />
      <Setter Property="Foreground" Value="#F2FBF9" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style TargetType="Border" x:Key="PanelBorderStyle">
      <Setter Property="Background" Value="#0B1718" />
      <Setter Property="BorderBrush" Value="#1B3536" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style TargetType="Button" x:Key="ShellButtonStyle">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="Foreground" Value="#EEF8F6" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#0F1A1C" />
      <Setter Property="BorderBrush" Value="#223A3C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#122022" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#315659" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#0B1415" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button" x:Key="ModuleActionButtonStyle" BasedOn="{StaticResource ShellButtonStyle}">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="#101B1D" />
      <Setter Property="BorderBrush" Value="#284446" />
      <Setter Property="Foreground" Value="#EFF8F6" />
      <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style TargetType="Button" x:Key="ModuleEllipsisButtonStyle" BasedOn="{StaticResource ModuleActionButtonStyle}">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Width" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Button" x:Key="ModuleCardButtonStyle" BasedOn="{StaticResource ModuleActionButtonStyle}">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#0C1719" />
      <Setter Property="BorderBrush" Value="#2A4C4F" />
      <Setter Property="Foreground" Value="#F0FAF7" />
    </Style>

    <Style TargetType="Button" x:Key="ModuleCardMenuButtonStyle" BasedOn="{StaticResource ModuleEllipsisButtonStyle}">
      <Setter Property="Width" Value="38" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="#0C1719" />
      <Setter Property="BorderBrush" Value="#203B3D" />
      <Setter Property="Foreground" Value="#A7BBB7" />
    </Style>

    <Style TargetType="Button" x:Key="OverviewTileButtonStyle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="OverviewButtonChrome"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OverviewButtonChrome" Property="Background" Value="#0D191B" />
                <Setter TargetName="OverviewButtonChrome" Property="BorderBrush" Value="#2C6165" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="OverviewButtonChrome" Property="Background" Value="#081213" />
                <Setter TargetName="OverviewButtonChrome" Property="BorderBrush" Value="#214A4E" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ItemsControl" x:Key="HomeCardsItemsControlStyle">
      <Setter Property="Margin" Value="0,14,0,0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="ItemsControl" x:Key="HomeModuleGridItemsControlStyle" BasedOn="{StaticResource HomeCardsItemsControlStyle}">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="Button" x:Key="HomeCardButtonStyle" BasedOn="{StaticResource OverviewTileButtonStyle}">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Border" x:Key="HomeCardBorderBaseStyle">
      <Setter Property="Width" Value="228" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Height" Value="92" />
      <Setter Property="Margin" Value="0,0,8,18" />
      <Setter Property="Padding" Value="14,11" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#244548" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#091314" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#0D191B" />
          <Setter Property="BorderBrush" Value="#2C6165" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="Border" x:Key="OverviewCardBorderStyle" BasedOn="{StaticResource HomeCardBorderBaseStyle}" />

    <Style TargetType="Border" x:Key="GuideCardBorderStyle">
      <Setter Property="Width" Value="232" />
      <Setter Property="Height" Value="148" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#214244" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#091314" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#0D191B" />
          <Setter Property="BorderBrush" Value="#2C6165" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="Border" x:Key="HomeModuleCardBorderStyle" BasedOn="{StaticResource HomeCardBorderBaseStyle}" />

    <Style TargetType="Border" x:Key="HomeCardMonogramBorderStyle">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="CornerRadius" Value="17" />
      <Setter Property="BorderThickness" Value="1.3" />
      <Setter Property="Background" Value="#0C1719" />
      <Setter Property="Margin" Value="0,0,9,0" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeCardMonogramTextStyle">
      <Setter Property="FontFamily" Value="Cascadia Mono" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeCardTitleStyle">
      <Setter Property="FontFamily" Value="Segoe UI Semibold" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="Foreground" Value="#F0FAF7" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeCardMetaStyle">
      <Setter Property="Margin" Value="0,2,0,0" />
      <Setter Property="FontFamily" Value="Cascadia Mono" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeCardBodyStyle">
      <Setter Property="Margin" Value="0,2,0,0" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="Foreground" Value="#A8C0BA" />
    </Style>

    <Style TargetType="StackPanel" x:Key="HomeCardStatusRowStyle">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style TargetType="Ellipse" x:Key="HomeCardStatusDotStyle">
      <Setter Property="Width" Value="7" />
      <Setter Property="Height" Value="7" />
      <Setter Property="Margin" Value="0,4,5,0" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeCardStatusTextStyle">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="Border" x:Key="HomeOverviewIconBorderStyle" BasedOn="{StaticResource HomeCardMonogramBorderStyle}">
      <Setter Property="BorderBrush" Value="#1FB9CB" />
      <Setter Property="Background" Value="#0C1516" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeOverviewIconTextStyle">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#23E7DB" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HomeOverviewStatusTextStyle" BasedOn="{StaticResource HomeCardStatusTextStyle}">
      <Setter Property="Foreground" Value="#97DF48" />
    </Style>

    <DataTemplate x:Key="InstalledHomeModuleCardTemplate">
      <Button Style="{StaticResource HomeCardButtonStyle}"
              Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
              CommandParameter="{Binding}">
        <Border Style="{StaticResource HomeModuleCardBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Style="{StaticResource HomeCardMonogramBorderStyle}"
                      BorderBrush="{Binding AccentBrush}">
                <TextBlock Text="{Binding Monogram}"
                           Style="{StaticResource HomeCardMonogramTextStyle}"
                           Foreground="{Binding AccentBrush}" />
              </Border>
              <StackPanel Grid.Column="1"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource HomeCardTitleStyle}" />
                <TextBlock Text="{Binding Kind, StringFormat=// {0}}"
                           Style="{StaticResource HomeCardMetaStyle}"
                           Foreground="{Binding AccentBrush}" />
              </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1"
                        Style="{StaticResource HomeCardStatusRowStyle}">
              <Ellipse Style="{StaticResource HomeCardStatusDotStyle}"
                       Fill="{Binding DisplayStatusBrush}" />
              <TextBlock Text="{Binding DisplayStateLabel}"
                         Style="{StaticResource HomeCardStatusTextStyle}"
                         Foreground="{Binding DisplayStatusBrush}" />
            </StackPanel>
          </Grid>
        </Border>
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="AvailableHomeModuleCardTemplate">
      <Button Style="{StaticResource HomeCardButtonStyle}"
              Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
              CommandParameter="{Binding}">
        <Border Style="{StaticResource HomeModuleCardBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Style="{StaticResource HomeCardMonogramBorderStyle}"
                      BorderBrush="{Binding AccentBrush}">
                <TextBlock Text="{Binding Monogram}"
                           Style="{StaticResource HomeCardMonogramTextStyle}"
                           Foreground="{Binding AccentBrush}" />
              </Border>
              <StackPanel Grid.Column="1"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           Style="{StaticResource HomeCardTitleStyle}" />
                <TextBlock Text="{Binding Category, StringFormat=// {0}}"
                           Style="{StaticResource HomeCardMetaStyle}"
                           Foreground="{Binding AccentBrush}" />
              </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1"
                        Style="{StaticResource HomeCardStatusRowStyle}">
              <Ellipse Style="{StaticResource HomeCardStatusDotStyle}"
                       Fill="{Binding StatusBrush}" />
              <TextBlock Text="{Binding AvailabilityLabel}"
                         Style="{StaticResource HomeCardStatusTextStyle}"
                         Foreground="{Binding StatusBrush}" />
            </StackPanel>
          </Grid>
        </Border>
      </Button>
    </DataTemplate>

    <Style TargetType="Button" x:Key="TopBarButtonStyle">
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Padding" Value="11,6" />
      <Setter Property="Foreground" Value="#EEF8F6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#0D1517" />
      <Setter Property="BorderBrush" Value="#445A5C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#121D1F" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#587376" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#091113" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button" x:Key="TopBarIconButtonStyle" BasedOn="{StaticResource TopBarButtonStyle}">
      <Setter Property="Width" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="ToggleButton" x:Key="RuntimeMonitorToggleStyle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#173436" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Foreground" Value="#8FB2AD" />
      <Setter Property="FontFamily" Value="Cascadia Mono" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="ToggleChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="#245456" />
                <Setter Property="Foreground" Value="#23E7DB" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="ToggleChrome" Property="Background" Value="#081314" />
                <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="#2A5B5E" />
                <Setter Property="Foreground" Value="#97DF48" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Button" x:Key="MonitorExitButtonStyle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#173436" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Foreground" Value="#23E7DB" />
      <Setter Property="FontFamily" Value="Cascadia Mono" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#2A5B5E" />
                <Setter TargetName="ButtonChrome" Property="Background" Value="#081314" />
                <Setter Property="Foreground" Value="#97DF48" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#050C0D" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ListBoxItem" x:Key="NavigationListBoxItemStyle">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
	          <ControlTemplate TargetType="ListBoxItem">
	            <Grid>
	              <Border x:Name="SelectedTint"
	                      BorderBrush="Transparent"
	                      BorderThickness="0"
	                      CornerRadius="4"
	                      Opacity="0">
	                <Border.Background>
	                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
	                    <GradientStop Color="#B2355D2A" Offset="0" />
	                    <GradientStop Color="#8E1D3E20" Offset="0.24" />
	                    <GradientStop Color="#50102423" Offset="0.58" />
	                    <GradientStop Color="#12071112" Offset="1" />
	                  </LinearGradientBrush>
	                </Border.Background>
	              </Border>
	              <Border x:Name="HoverOutline"
	                      Background="Transparent"
	                      BorderBrush="#163234"
	                      BorderThickness="0.45"
	                      CornerRadius="4"
	                      Opacity="0" />
	              <Border x:Name="SelectedEdge"
	                      Width="3"
	                      CornerRadius="3,0,0,3"
	                      Background="#8CFF55"
                      HorizontalAlignment="Left"
                      Margin="-1,0,0,0"
                      Opacity="0" />
              <ContentPresenter Margin="12,8" />
            </Grid>
	            <ControlTemplate.Triggers>
	              <Trigger Property="IsSelected" Value="True">
	                <Setter TargetName="SelectedTint" Property="Opacity" Value="1" />
	                <Setter TargetName="SelectedEdge" Property="Opacity" Value="1" />
	              </Trigger>
	              <Trigger Property="IsMouseOver" Value="True">
	                <Setter TargetName="HoverOutline" Property="Opacity" Value="0.82" />
	              </Trigger>
	              <MultiTrigger>
	                <MultiTrigger.Conditions>
	                  <Condition Property="IsMouseOver" Value="True" />
	                  <Condition Property="IsSelected" Value="False" />
	                </MultiTrigger.Conditions>
	                <Setter TargetName="SelectedTint" Property="Opacity" Value="0.18" />
	              </MultiTrigger>
	              <MultiTrigger>
	                <MultiTrigger.Conditions>
	                  <Condition Property="IsMouseOver" Value="True" />
	                  <Condition Property="IsSelected" Value="True" />
	                </MultiTrigger.Conditions>
	                <Setter TargetName="HoverOutline" Property="BorderBrush" Value="#2C6F43" />
	              </MultiTrigger>
	            </ControlTemplate.Triggers>
	          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="RepeatButton" x:Key="LogScrollRepeatButtonStyle">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border Background="Transparent" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="Thumb" x:Key="LogScrollThumbStyle">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="ThumbChrome"
                    Width="8"
                    Margin="2,0"
                    CornerRadius="4"
                    Background="#2AA8A2" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbChrome" Property="Background" Value="#35C8C0" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbChrome" Property="Background" Value="#23E7DB" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ScrollBar" x:Key="LogScrollBarStyle">
      <Setter Property="Width" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Width="12"
                  Background="#0A1516">
              <Border BorderBrush="#123030"
                      BorderThickness="1,0,0,0" />
              <Track x:Name="PART_Track"
                     IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                Style="{StaticResource LogScrollRepeatButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Style="{StaticResource LogScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                Style="{StaticResource LogScrollRepeatButtonStyle}" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

	    <Grid>
	      <Grid.ColumnDefinitions>
	      <ColumnDefinition x:Name="SidebarColumn" Width="232" />
	      <ColumnDefinition x:Name="ShellGutterColumn" Width="8" />
	      <ColumnDefinition x:Name="MainContentColumn" Width="*" />
	    </Grid.ColumnDefinitions>

	    <Border Grid.Column="0"
              x:Name="SidebarRoot"
              SizeChanged="SidebarRoot_SizeChanged"
	            Background="#020708"
	            BorderBrush="#173436"
	            BorderThickness="0,0,1,0">
	      <Grid>
	        <Grid.RowDefinitions>
	          <RowDefinition Height="Auto" />
	          <RowDefinition Height="*" />
	          <RowDefinition Height="Auto" />
	        </Grid.RowDefinitions>

        <Grid x:Name="SidebarHeader"
              Grid.Row="0"
              Panel.ZIndex="2"
              Background="Transparent"
              Margin="14,18,12,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DockPanel LastChildFill="False">
            <Image Source="/AppAssets/NymphsCore_logo.png"
                   Width="200"
                   Stretch="Uniform"
                   HorizontalAlignment="Left" />
          </DockPanel>
          <DockPanel Grid.Row="1"
                     Margin="2,6,0,0"
                     LastChildFill="False">
            <TextBlock Text="// GameDev Ai Pipelines"
                       Style="{StaticResource AccentTextStyle}" />
            <Button x:Name="MonitorModeToggleButton"
                    DockPanel.Dock="Right"
                    Style="{StaticResource MonitorExitButtonStyle}"
                    Width="38"
                    Height="20"
                    Margin="8,-1,0,0"
                    Padding="0"
                    Click="MonitorModeToggleButton_Click">
              <TextBlock x:Name="MonitorModeToggleText"
                         Text="mon"
                         FontSize="9.5"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Button>
          </DockPanel>
        </Grid>

	        <Grid Grid.Row="0"
	              Grid.RowSpan="3"
	              Panel.ZIndex="0"
	              Margin="8,0,0,0">
          <Rectangle Fill="#020708" />

          <Grid IsHitTestVisible="False"
                Margin="0">
            <Image Source="{Binding CurrentSidebarArtPath}"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Opacity="0.30">
              <Image.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                  <BeginStoryboard>
                    <Storyboard AutoReverse="True"
                                RepeatBehavior="Forever">
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="0.18"
                                       To="0.36"
                                       Duration="0:0:4.2" />
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Image.Triggers>
            </Image>
          </Grid>
        </Grid>

        <Grid x:Name="SidebarNavHost"
              Grid.Row="1"
              Panel.ZIndex="2"
              Margin="10,16,40,8"
              ClipToBounds="True">
          <ListBox ItemsSource="{Binding PrimaryNavigationItems}"
                   SelectedItem="{Binding SelectedNavigationItem}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Glyph}"
                             FontFamily="Segoe Fluent Icons"
                             FontSize="19"
                             VerticalAlignment="Center"
                             Foreground="{Binding AccentBrush}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Label}"
                              VerticalAlignment="Center">
                    <TextBlock.FontFamily>Segoe UI Semibold</TextBlock.FontFamily>
                    <TextBlock.FontSize>14</TextBlock.FontSize>
                    <TextBlock.Foreground>#EEF9F6</TextBlock.Foreground>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

	        <Border x:Name="SidebarRuntimePanel"
                  Grid.Row="2"
	                BorderBrush="Transparent"
	                BorderThickness="0"
	                Margin="0">
          <StackPanel Margin="22,18,22,18"
                      VerticalAlignment="Bottom">
          <TextBlock Text="// RUNTIME"
                     Style="{StaticResource MonoLabelStyle}"
                     Foreground="{StaticResource LimeBrush}" />
          <DockPanel Margin="0,8,0,0"
                     LastChildFill="False">
            <TextBlock Text="{Binding RuntimePanelTitle}"
                       Foreground="#E7F5F2"
                       FontFamily="Segoe UI Semibold"
                       FontSize="13"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding RuntimePanelStatusLabel}"
                       Foreground="{Binding RuntimePanelStatusBrush}"
                       FontFamily="Segoe UI Semibold"
                       FontSize="13" />
          </DockPanel>
          <TextBlock Margin="0,8,0,0"
                     Text="{Binding RuntimeCpuUsageLabel, StringFormat=CPU: {0}}"
                     Foreground="#56E6DC"
                     FontSize="12" />
          <TextBlock Margin="0,3,0,0"
                     Text="{Binding RuntimeMemoryUsageLabel, StringFormat=RAM: {0}}"
                     Foreground="#7CF0C1"
                     FontSize="12" />
          <TextBlock Margin="0,3,0,0"
                     Text="{Binding RuntimeDiskUsageLabel, StringFormat=WSL Disk: {0}}"
                     Foreground="#B4F05D"
                     FontSize="12" />
          <TextBlock Margin="0,3,0,0"
                     Text="{Binding RuntimeWindowsDiskUsageLabel, StringFormat=Win Disk: {0}}"
                     Foreground="#8ED8FF"
                     FontSize="12" />
          <TextBlock Margin="0,3,0,0"
                     Text="{Binding RuntimeGpuVramLabel, StringFormat=GPU VRAM: {0}}"
                     Foreground="#FFD166"
                     FontSize="12" />
          <TextBlock Margin="0,3,0,0"
                     Text="{Binding RuntimeGpuTempLabel, StringFormat=GPU Temp: {0}}"
                     Foreground="#FF9E57"
                     FontSize="12" />
          <ToggleButton x:Name="BrainMonitorToggle"
                        Margin="0,8,0,0"
                        Style="{StaticResource RuntimeMonitorToggleStyle}">
            <DockPanel LastChildFill="True">
              <TextBlock DockPanel.Dock="Right"
                         Text="+"
                         Margin="8,0,0,0"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
              <TextBlock Text="// BRAIN MONITOR"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
            </DockPanel>
          </ToggleButton>
          <StackPanel Margin="0,6,0,0"
                      Visibility="{Binding IsChecked, ElementName=BrainMonitorToggle, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding RuntimeBrainLlmStateLabel}"
                       Foreground="#E7F5F2"
                       FontFamily="Segoe UI Semibold"
                       FontSize="12" />
            <TextBlock Margin="0,3,0,0"
                       Text="{Binding RuntimeBrainTokensPerSecondLabel}"
                       Foreground="#FFD166"
                       FontSize="12" />
            <TextBlock Margin="0,3,0,0"
                       Text="{Binding RuntimeBrainContextLabel}"
                       Foreground="#8ED8FF"
                       FontSize="12" />
            <TextBlock Margin="0,3,0,0"
                       Text="{Binding RuntimeBrainModelLabel}"
                       Foreground="#9BB9B4"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <TextBlock Margin="0,8,0,0"
                     Text="{Binding LastRefreshedText}"
                     Style="{StaticResource AccentTextStyle}"
                     FontSize="12.5" />
          <StackPanel x:Name="SidebarFooterHost">
            <Rectangle Margin="0,12,0,12"
                       Height="1"
                       Fill="#173436"
                       Opacity="0.85" />
            <TextBlock Text="{Binding AppVersionLabel}"
                       Foreground="#CFE4DE"
                       FontFamily="Segoe UI Semibold"
                       FontSize="13" />
            <TextBlock Margin="0,4,0,0"
                       Style="{StaticResource AccentTextStyle}"
                       FontSize="14">
              <Hyperlink Command="{Binding OpenSourceCommand}"
                         Foreground="{StaticResource AccentBrush}"
                         TextDecorations="{x:Null}">
                <Run Text="Open Source" />
              </Hyperlink>
            </TextBlock>
          </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="MainContentShell"
          Grid.Column="2"
          Margin="22,0,22,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            Margin="0,24,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Height="78">
          <TextBlock Text="{Binding CurrentPageTitle}"
                     Margin="0,2,0,0"
                     VerticalAlignment="Top"
                     Style="{StaticResource PageTitleStyle}" />
          <TextBlock Text="{Binding CurrentPageSubtitle, StringFormat=// {0}}"
                     Margin="0,45,0,0"
                     VerticalAlignment="Top"
                     Style="{StaticResource PageSubtitleStyle}" />
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Top">
          <Button Style="{StaticResource TopBarButtonStyle}"
                  Command="{Binding CheckForUpdatesCommand}"
                  MinWidth="144"
                  Height="36">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE895;"
                         FontFamily="Segoe Fluent Icons"
                         FontSize="14"
                         Margin="0,0,7,0"
                         VerticalAlignment="Center" />
              <TextBlock Text="Check for Updates"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button x:Name="SettingsButton"
                  Style="{StaticResource TopBarIconButtonStyle}"
                  BorderBrush="{Binding DeveloperModeBrush}"
                  Click="SettingsButton_Click"
                  Height="36">
            <TextBlock Text="&#xE713;"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Button>
        </StackPanel>

        <Popup x:Name="SettingsPopup"
               Grid.Column="1"
               PlacementTarget="{Binding ElementName=SettingsButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False">
          <Border Margin="0,6,0,0"
                  Width="190"
                  Padding="10"
                  CornerRadius="6"
                  Background="#0A1415"
                  BorderBrush="#284446"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock Text="// SETTINGS"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}"
                         FontSize="12" />
              <CheckBox Margin="0,10,0,0"
                        IsChecked="{Binding IsDeveloperMode, Mode=TwoWay}"
                        Foreground="#E4F2EF"
                        FontFamily="Segoe UI Semibold"
                        FontSize="12"
                        Content="Developer Mode" />
            </StackPanel>
          </Border>
        </Popup>
      </Grid>

      <ScrollViewer x:Name="MainContentScrollViewer"
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled"
                    CanContentScroll="False"
                    PanningMode="VerticalOnly">
        <Grid>
          <Grid Visibility="{Binding IsHomePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <StackPanel Grid.Row="0"
                          Margin="{StaticResource HomeSectionSpacing}">
                <TextBlock Text="// SYSTEM OVERVIEW"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeOverviewCardTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <Button Style="{StaticResource HomeCardButtonStyle}"
                          Command="{Binding ShowSystemChecksCommand}">
                    <Border Style="{StaticResource OverviewCardBorderStyle}">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Style="{StaticResource HomeOverviewIconBorderStyle}">
                            <TextBlock Text="&#xE895;"
                                       Style="{StaticResource HomeOverviewIconTextStyle}" />
                          </Border>
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center">
                            <TextBlock Text="System Checks"
                                       Style="{StaticResource HomeCardTitleStyle}"
                                       Foreground="#EEF8F6" />
                            <TextBlock Text="Shared platform checks"
                                       Style="{StaticResource HomeCardBodyStyle}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1"
                                    Style="{StaticResource HomeCardStatusRowStyle}">
                          <TextBlock Text="{Binding SystemChecksSummary}"
                                     Style="{StaticResource HomeOverviewStatusTextStyle}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Button>
                  <Button Style="{StaticResource HomeCardButtonStyle}"
                          Command="{Binding ShowBaseRuntimeCommand}">
                    <Border Style="{StaticResource OverviewCardBorderStyle}">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Style="{StaticResource HomeOverviewIconBorderStyle}">
                            <TextBlock Text="&#xE756;"
                                       Style="{StaticResource HomeOverviewIconTextStyle}" />
                          </Border>
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center">
                            <TextBlock Text="Base Runtime"
                                       Style="{StaticResource HomeCardTitleStyle}"
                                       Foreground="#EEF8F6" />
                            <TextBlock Text="{Binding BaseRuntimeCardSubtitle}"
                                       Style="{StaticResource HomeCardBodyStyle}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1"
                                    Style="{StaticResource HomeCardStatusRowStyle}">
                          <TextBlock Text="{Binding BaseRuntimeCardStatus}"
                                     Style="{StaticResource HomeOverviewStatusTextStyle}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Button>
                </ItemsControl>
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Margin="{StaticResource HomeModuleSectionSpacing}"
                          Visibility="{Binding ShowInstalledModulesSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                  <TextBlock Text="// INSTALLED MODULES"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                </DockPanel>
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeCardsTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}"
                              ItemsSource="{Binding HomeInstalledModules}"
                              ItemTemplate="{StaticResource InstalledHomeModuleCardTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>

              <StackPanel Grid.Row="2"
                          Margin="{StaticResource HomeModuleSectionSpacing}"
                          Visibility="{Binding ShowAvailableModulesSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                  <TextBlock Text="// AVAILABLE MODULES"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                </DockPanel>
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeCardsTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}"
                              ItemsSource="{Binding HomeAvailableModules}"
                              ItemTemplate="{StaticResource AvailableHomeModuleCardTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>
            </Grid>
          </Grid>

          <Grid Visibility="{Binding IsBaseRuntimePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="232" />
              </Grid.ColumnDefinitions>

              <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                <DockPanel LastChildFill="False">
                  <Border Width="48"
                          Height="48"
                          CornerRadius="14"
                          Background="#0A1717"
                          BorderBrush="#23E7DB"
                          BorderThickness="1"
                          Margin="0,0,12,0">
                    <TextBlock Text="WS"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Cascadia Mono"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#23E7DB" />
                  </Border>
                  <StackPanel>
                    <TextBlock Text="Base Runtime"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="32"
                               Foreground="#F2FBF9" />
                    <TextBlock Text="{Binding BaseRuntimeStatusLabel}"
                               Foreground="{Binding BaseRuntimeStatusBrush}"
                               FontWeight="Bold"
                               FontSize="16" />
                  </StackPanel>
                </DockPanel>

                <TextBlock Margin="0,8,0,0"
                           Text="Managed WSL shell, platform status, and repair actions."
                           Foreground="#B1C9C5"
                           FontSize="13"
                           TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="14,10"
                        Background="#0A1415"
                        VerticalAlignment="Stretch">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                      <TextBlock Text="// BASE RUNTIME GUIDE"
                                 Style="{StaticResource MonoLabelStyle}"
                                 Foreground="{StaticResource LimeBrush}" />
                      <TextBlock Margin="0,6,0,0"
                                 Text="Use this order: get Windows WSL ready, install the NymphsCore runtime, then add modules from their cards."
                                 Foreground="#D8EAE6"
                                 FontWeight="SemiBold"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Rows="3"
                                 Columns="1"
                                 Margin="0,10,0,0">
                      <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="01"
                                   Foreground="#97DF48"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Check Windows WSL"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Look at Current State. If Windows WSL says Ready, skip the setup button and install Base Runtime."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>

                      <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="02"
                                   Foreground="#23E7DB"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Set Up Windows WSL only if needed"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Use this when Windows WSL is missing or not ready. Approve any Windows prompt, restart if asked, then reopen Manager."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>

                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="03"
                                   Foreground="#D77CD1"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Install Base Runtime, then modules"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Base Runtime creates the managed Ubuntu shell named NymphsCore. After that, install each module from its card."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </UniformGrid>
                  </Grid>
                </Border>

                <StackPanel Grid.Row="2"
                            Margin="0,7,0,0">
                  <TextBlock Text="// RUNTIME PROGRESS"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                  <Border Margin="0,6,0,0"
                          Style="{StaticResource PanelBorderStyle}"
                          Padding="9,8"
                          MinHeight="52"
                          Background="#081314">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding BaseRuntimeOperationLabel}"
                                 Foreground="#97DF48"
                                 FontFamily="Cascadia Mono"
                                 FontSize="12"
                                 Margin="0,0,14,0"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding BaseRuntimeProgressText}"
                                 Foreground="#7FF7EF"
                                 FontFamily="Cascadia Mono"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 MaxHeight="40"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Grid>

              <StackPanel Grid.Column="2">
                <TextBlock Text="// ACTIONS"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <Button Margin="0,10,0,6"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding SetupWindowsWslCommand}"
                        Content="{Binding SetupWindowsWslActionText}" />
                <Button Margin="0,0,0,6"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding SetupBaseRuntimeCommand}"
                        Content="{Binding BaseRuntimeActionText}" />
                <Button Margin="0,0,0,6"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding UninstallBaseRuntimeCommand}"
                        Content="Unregister WSL Runtime" />
                <Button Margin="0"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding ShowHomeCommand}"
                        Content="Back To Home" />

                <Border Margin="0,10,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="10"
                        Background="#081314">
                  <StackPanel>
                    <TextBlock Text="// CURRENT STATE"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Margin="0,7,0,0"
                               Text="{Binding WindowsWslStatusLabel, StringFormat=Windows WSL: {0}}"
                               Foreground="{Binding WindowsWslStatusBrush}"
                               FontSize="12" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{Binding BaseRuntimeStatusLabel, StringFormat=Status: {0}}"
                               Foreground="#D8EAE6"
                               FontSize="12" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{Binding BaseRuntimeCardSubtitle, StringFormat=Base runtime: {0}}"
                               Foreground="#D8EAE6"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{Binding RuntimePanelSummary}"
                               Foreground="#9AB8B4"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{Binding RuntimeDiskUsageLabel, StringFormat=WSL disk: {0}}"
                               Foreground="#9AB8B4"
                               FontSize="11" />
                    <TextBlock Margin="0,5,0,0"
                               Text="{Binding RuntimeWindowsDiskUsageLabel, StringFormat=Win disk: {0}}"
                               Foreground="#9AB8B4"
                               FontSize="11" />
                  </StackPanel>
                </Border>
                <Border Margin="0,8,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="9"
                        Background="#100F0A"
                        BorderBrush="#4A3820">
                  <TextBlock Text="Unregister removes the managed WSL distro, its runtime folder, and modules installed inside it."
                             Foreground="#D9B36B"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Grid>
          </Grid>

          <Grid Visibility="{Binding IsSystemChecksPage, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="// SYSTEM CHECKS"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
              <TextBlock Margin="0,10,0,0"
                         Text="Detailed readiness checks for the shared WSL runtime, install targets, GPU support, and current platform state."
                         Foreground="#A2C0BC"
                         TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding SystemChecks}"
                            Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="16"
                            CornerRadius="8"
                            BorderBrush="#183435"
                            BorderThickness="1"
                            Background="#0A1415">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="16"
                                     Foreground="#F0FAF7" />
                          <TextBlock Margin="0,8,0,0"
                                     Text="{Binding Description}"
                                     Foreground="#BCD2CE"
                                     FontSize="12"
                                     TextWrapping="Wrap" />
                          <TextBlock Margin="0,10,0,0"
                                     Text="{Binding Details}"
                                     Foreground="#8FAAA5"
                                     FontSize="11.5"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                MinWidth="78"
                                Background="{Binding StatusBadgeBackground}"
                                BorderBrush="#173739"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="9,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                          <TextBlock Text="{Binding StatusLabel}"
                                     Foreground="#F4FCFA"
                                     FontWeight="Bold"
                                     FontSize="11.5"
                                     TextAlignment="Center" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <Grid Visibility="{Binding IsLogsPage, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="{Binding ActualHeight, ElementName=MainContentScrollViewer}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <TextBlock Text="// LOG STREAM"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
            </Grid>
            <Border Grid.Row="1"
                      Margin="0,12,0,0"
                      Background="#081112"
                      BorderBrush="#173435"
                      BorderThickness="1"
                      Padding="14">
                <TextBox x:Name="UnifiedLogTextBox"
                         Text="{Binding UnifiedLogText, Mode=OneWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         Foreground="#8FD7D0"
                         CaretBrush="#23E7DB"
                         SelectionBrush="#2AA8A2"
                         SelectionOpacity="0.38"
                         FontFamily="Consolas"
                         FontSize="11"
                         FontWeight="Light"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         MinHeight="0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalScrollBarVisibility="Visible"
                         HorizontalScrollBarVisibility="Disabled">
                  <TextBox.Resources>
                    <Style TargetType="ScrollBar"
                           BasedOn="{StaticResource LogScrollBarStyle}" />
                  </TextBox.Resources>
                </TextBox>
              </Border>
          </Grid>

          <Grid Visibility="{Binding IsGuidePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="// GUIDE"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
              <TextBlock Margin="0,12,0,18"
                         Text="This shell keeps only core references here: general guidance, Manager README, footprint docs, and addon docs. Module-deep controls belong on module pages."
                         Foreground="#A2C0BC"
                         TextWrapping="Wrap" />

              <WrapPanel>
                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Core Guide"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the main public guide for the shared platform."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenGuideCommand}"
                            Content="Open Guide" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Manager README"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the current Manager README and implementation notes."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenReadmeCommand}"
                            Content="Open README" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Addon Guide"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the external addon documentation that sits outside the Nymph layer."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenAddonGuideCommand}"
                            Content="Open Addon Guide" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Footprint"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the footprint notes for shared runtime expectations."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenFootprintCommand}"
                            Content="Open Footprint Doc" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </StackPanel>
          </Grid>

          <Grid Visibility="{Binding IsModulePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Visibility="{Binding HasSelectedModule, Converter={StaticResource BoolToVisibilityConverter}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="232" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <DockPanel LastChildFill="False">
                  <Border Width="56"
                          Height="56"
                          CornerRadius="16"
                          Background="#0A1717"
                          BorderBrush="{Binding DisplayedModule.AccentBrush}"
                          BorderThickness="1"
                          Margin="0,0,14,0">
                    <TextBlock Text="{Binding DisplayedModule.Monogram}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Cascadia Mono"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{Binding DisplayedModule.AccentBrush}" />
                  </Border>
                  <StackPanel>
                    <TextBlock Text="{Binding DisplayedModule.Name}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="38"
                               Foreground="#F2FBF9" />
                    <TextBlock Text="{Binding DisplayedModule.DisplayStateLabel}"
                               Foreground="{Binding DisplayedModule.DisplayStatusBrush}"
                               FontWeight="Bold"
                               FontSize="18" />
                  </StackPanel>
                </DockPanel>

                <TextBlock Margin="0,18,0,0"
                           Text="{Binding DisplayedModule.Description}"
                           Foreground="#B1C9C5"
                           FontSize="16"
                           TextWrapping="Wrap" />

                <Border Margin="0,18,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16"
                        Background="#0A1415"
                        Height="170">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="// LIVE DETAIL"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="{Binding ModuleActionFeedbackTitle}"
                               Foreground="#D8EAE6"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2"
                                  Margin="0,8,0,0"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                      <TextBlock Text="{Binding ModuleActionFeedbackDetail}"
                                 Foreground="#9AB8B4"
                                 FontSize="12"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </Grid>
                </Border>

                <TextBlock Margin="0,16,0,10"
                           Text="// MANAGER CONTRACT"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <ItemsControl ItemsSource="{Binding DisplayedModule.Capabilities}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Margin="0,0,10,10"
                              Style="{StaticResource ModuleActionButtonStyle}"
                              Command="{Binding DataContext.RunModuleActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}">
                        <TextBlock Text="{Binding StringFormat=// {0}}"
                                   Foreground="#23E7DB"
                                   FontFamily="Cascadia Mono"
                                   FontSize="12" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,14,0,0"
                            Visibility="{Binding ShowDevContract, Converter={StaticResource BoolToVisibilityConverter}}">
                  <TextBlock Margin="0,0,0,10"
                             Text="// DEV CONTRACT"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                  <ItemsControl ItemsSource="{Binding DisplayedModule.DevCapabilities}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource ModuleActionButtonStyle}"
                                Command="{Binding DataContext.RunModuleDevActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                          <TextBlock Text="{Binding StringFormat=// {0}}"
                                     Foreground="#97DF48"
                                     FontFamily="Cascadia Mono"
                                     FontSize="12" />
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16"
                        Background="#081314"
                        Visibility="{Binding ShowModuleLogs, Converter={StaticResource BoolToVisibilityConverter}}">
                  <StackPanel>
                    <TextBlock Text="// MODULE LOGS"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding ModuleLogsTitle}"
                               Foreground="#D8EAE6"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <ScrollViewer Margin="0,10,0,0"
                                  MaxHeight="210"
                                  VerticalScrollBarVisibility="Hidden">
                      <TextBlock Text="{Binding ModuleLogsDetail}"
                                 Foreground="#7FF7EF"
                                 FontFamily="Cascadia Mono"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="// ACTIONS"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <Button Margin="0,16,0,10"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding InstallModuleCommand}"
                        CommandParameter="{Binding DisplayedModule}"
                        Visibility="{Binding ShowInstallModuleAction, Converter={StaticResource BoolToVisibilityConverter}}"
                        Content="Install Module" />
                <Button Margin="0,16,0,10"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding OpenModuleInstallPathCommand}"
                        CommandParameter="{Binding DisplayedModule}"
                        Visibility="{Binding ShowInstalledModuleActions, Converter={StaticResource BoolToVisibilityConverter}}"
                        Content="Open Install Folder" />
                <Button Margin="0,0,0,10"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding UpdateModuleCommand}"
                        CommandParameter="{Binding DisplayedModule}"
                        Visibility="{Binding DisplayedModule.HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}"
                        Content="Update Module" />
                <Button Margin="0,0,0,10"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding UninstallModuleCommand}"
                        CommandParameter="{Binding DisplayedModule}"
                        Visibility="{Binding ShowInstalledModuleActions, Converter={StaticResource BoolToVisibilityConverter}}"
                        Content="Uninstall Module" />
                <Button Margin="0,0,0,10"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding DeleteModuleCommand}"
                        CommandParameter="{Binding DisplayedModule}"
                        Visibility="{Binding ShowDeleteModuleData, Converter={StaticResource BoolToVisibilityConverter}}"
                        Content="Delete Module + Data" />
                <Button Margin="0"
                        Style="{StaticResource ShellButtonStyle}"
                        Command="{Binding ShowHomeCommand}"
                        Content="Back To Home" />
                <Border Margin="0,18,0,0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="14"
                        Background="#081314">
                  <StackPanel>
                    <TextBlock Text="// MODULE FACTS"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding DisplayedModule.Category, StringFormat=Category: {0}}"
                               Foreground="#D8EAE6"
                               FontSize="12" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DisplayedModule.Kind, StringFormat=Packaging: {0}}"
                               Foreground="#D8EAE6"
                               FontSize="12" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DisplayedModule.VersionLabel, StringFormat=Installed: {0}}"
                               Foreground="#D8EAE6"
                               FontSize="12" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DisplayedModule.RemoteVersionLabel, StringFormat=Remote: {0}}"
                               Foreground="#9AB8B4"
                               FontSize="11" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DisplayedModule.InstallPathLabel, StringFormat=Install path: {0}}"
                               Foreground="#9AB8B4"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#9AB8B4"
                               FontSize="11"
                               Visibility="{Binding DisplayedModule.HasRepositoryUrl, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Run Text="Source: " />
                      <Hyperlink Command="{Binding OpenModuleSourceCommand}"
                                 CommandParameter="{Binding DisplayedModule}"
                                 Foreground="{StaticResource AccentBrush}"
                                 TextDecorations="{x:Null}">
                        <Run Text="GitHub" />
                      </Hyperlink>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </Grid>
        </Grid>
      </ScrollViewer>

      <Border Grid.Row="2"
              Margin="0,8,0,8"
              Padding="8,5"
              Background="#081314"
              BorderBrush="#173436"
              BorderThickness="1,1,1,0">
        <DockPanel LastChildFill="True">
          <TextBlock Text="{Binding DeveloperModeLabel}"
                     DockPanel.Dock="Right"
                     Margin="12,0,0,0"
                     Foreground="{Binding DeveloperModeBrush}"
                     FontFamily="Cascadia Mono"
                     FontSize="10.5"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding BottomStatusText}"
                     Foreground="#8FB2AD"
                     FontFamily="Cascadia Mono"
                     FontSize="10.5"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>
    </Grid>

	  </Grid>
	</Window>
