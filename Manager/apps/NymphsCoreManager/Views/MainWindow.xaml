	                      Command="{Binding InstallModuleCommand}"
	                      CommandParameter="{Binding DisplayedModule}"
	                      Content="Install" />
	              <Button Style="{StaticResource ManageLinkButtonStyle}"
	                      Command="{Binding UpdateModuleCommand}"
	                      CommandParameter="{Binding DisplayedModule}"
	                      Content="Update" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding RepairModuleCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
                      Content="Repair" />
              <Button Style="{StaticResource ManageLinkButtonStyle}"
                      Command="{Binding OpenModelCacheCommand}"
                      Content="Model Cache" />
              <Button Style="{StaticResource ManageLinkButtonStyle}"
                      Command="{Binding OpenModuleInstallPathCommand}"
                      CommandParameter="{Binding DisplayedModule}"
                      Content="Directory" />
              <Button Style="{StaticResource ManageLinkButtonStyle}"
                      Command="{Binding UninstallModuleCommand}"
                      CommandParameter="{Binding DisplayedModule}"
                      Content="Uninstall" />
            </StackPanel>
          </Border>
        </Popup>

        <Popup x:Name="SettingsPopup"
               Grid.Column="1"
               PlacementTarget="{Binding ElementName=SettingsButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False">
          <Border Margin="0,6,0,0"
                  Width="260"
                  Padding="10"
                  CornerRadius="6"
                  Background="#0A1415"
                  BorderBrush="#284446"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock Text="// SETTINGS"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}"
                         FontSize="12" />
              <CheckBox Margin="0,10,0,0"
                        IsChecked="{Binding IsDeveloperMode, Mode=TwoWay}"
                        Foreground="#E4F2EF"
                        FontFamily="Segoe UI Semibold"
                        FontSize="12"
                        Content="Developer Mode" />
              <Button Margin="0,12,0,0"
                      Style="{StaticResource ModuleActionButtonStyle}"
                      Command="{Binding CheckForUpdatesCommand}">
                <TextBlock Text="// check updates"
                           Foreground="#23E7DB"
                           FontFamily="Cascadia Mono"
                           FontSize="11" />
              </Button>
	              <StackPanel Margin="0,14,0,0"
	                          Visibility="{Binding IsModuleUiPage, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="// MODULE FACTS"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}"
                           FontSize="12" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding DisplayedModule.Category, StringFormat=Category: {0}}"
                           Foreground="#D8EAE6"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding DisplayedModule.Kind, StringFormat=Packaging: {0}}"
                           Foreground="#D8EAE6"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding DisplayedModule.VersionLabel, StringFormat=Installed: {0}}"
                           Foreground="#D8EAE6"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding DisplayedModule.RemoteVersionLabel, StringFormat=Remote: {0}}"
                           Foreground="#9AB8B4"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding DisplayedModule.InstallPathLabel, StringFormat=Install path: {0}}"
                           Foreground="#9AB8B4"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#9AB8B4"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Visibility="{Binding DisplayedModule.HasRepositoryUrl, Converter={StaticResource BoolToVisibilityConverter}}">
                  <Run Text="Source: " />
                  <Hyperlink Command="{Binding OpenModuleSourceCommand}"
                             CommandParameter="{Binding DisplayedModule}"
                             Foreground="{StaticResource AccentBrush}"
                             TextDecorations="{x:Null}">
                    <Run Text="GitHub" />
                  </Hyperlink>
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>
        </Popup>
      </Grid>

      <ScrollViewer x:Name="MainContentScrollViewer"
                    Grid.Row="1"
                    Visibility="{Binding IsStandardContentPage, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled"
                    CanContentScroll="False"
                    PanningMode="VerticalOnly">
        <Grid>
          <Grid Visibility="{Binding IsHomePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <StackPanel Grid.Row="0"
                          Margin="{StaticResource HomeSectionSpacing}">
                <TextBlock Text="// SYSTEM OVERVIEW"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeOverviewCardTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <Button Style="{StaticResource HomeCardButtonStyle}"
                          Command="{Binding ShowSystemChecksCommand}">
                    <Border Style="{StaticResource OverviewCardBorderStyle}">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Style="{StaticResource HomeOverviewIconBorderStyle}">
                            <TextBlock Text="&#xE895;"
                                       Style="{StaticResource HomeOverviewIconTextStyle}" />
                          </Border>
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center">
                            <TextBlock Text="System Checks"
                                       Style="{StaticResource HomeCardTitleStyle}"
                                       Foreground="#EEF8F6" />
                            <TextBlock Text="Shared platform checks"
                                       Style="{StaticResource HomeCardBodyStyle}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1"
                                    Style="{StaticResource HomeCardStatusRowStyle}">
                          <TextBlock Text="{Binding SystemChecksSummary}"
                                     Style="{StaticResource HomeOverviewStatusTextStyle}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Button>
                  <Button Style="{StaticResource HomeCardButtonStyle}"
                          Command="{Binding ShowBaseRuntimeCommand}">
                    <Border Style="{StaticResource OverviewCardBorderStyle}">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Style="{StaticResource HomeOverviewIconBorderStyle}">
                            <TextBlock Text="&#xE756;"
                                       Style="{StaticResource HomeOverviewIconTextStyle}" />
                          </Border>
                          <StackPanel Grid.Column="1"
                                      VerticalAlignment="Center">
                            <TextBlock Text="Base Runtime"
                                       Style="{StaticResource HomeCardTitleStyle}"
                                       Foreground="#EEF8F6" />
                            <TextBlock Text="{Binding BaseRuntimeCardSubtitle}"
                                       Style="{StaticResource HomeCardBodyStyle}" />
                          </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="1"
                                    Style="{StaticResource HomeCardStatusRowStyle}">
                          <TextBlock Text="{Binding BaseRuntimeCardStatus}"
                                     Style="{StaticResource HomeOverviewStatusTextStyle}" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Button>
                </ItemsControl>
              </StackPanel>
              <StackPanel Grid.Row="1"
                          Margin="{StaticResource HomeModuleSectionSpacing}"
                          Visibility="{Binding ShowInstalledModulesSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                  <TextBlock Text="// INSTALLED MODULES"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                </DockPanel>
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeCardsTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}"
                              ItemsSource="{Binding HomeInstalledModules}"
                              ItemTemplate="{StaticResource InstalledHomeModuleCardTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>

              <StackPanel Grid.Row="2"
                          Margin="{StaticResource HomeModuleSectionSpacing}"
                          Visibility="{Binding ShowAvailableModulesSection, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                  <TextBlock Text="// AVAILABLE MODULES"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                </DockPanel>
                <ItemsControl Style="{StaticResource HomeModuleGridItemsControlStyle}"
                              Margin="{StaticResource HomeCardsTopSpacing}"
                              Width="{Binding ActualWidth, ElementName=MainContentScrollViewer}"
                              ItemsSource="{Binding HomeAvailableModules}"
                              ItemTemplate="{StaticResource AvailableHomeModuleCardTemplate}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>
            </Grid>
          </Grid>

          <Grid Visibility="{Binding IsBaseRuntimePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Height="{Binding ActualHeight, ElementName=MainContentScrollViewer}"
                  MinHeight="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="138" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="64"
                        Height="64"
                        CornerRadius="16"
                        Background="#0A1717"
                        BorderBrush="#23E7DB"
                        BorderThickness="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        ToolTip="Show or hide sidebar"
                        MouseLeftButtonUp="ModuleLogoCollapseButton_MouseLeftButtonUp">
                  <TextBlock Text="WS"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontFamily="Cascadia Mono"
                             FontSize="17"
                             FontWeight="Bold"
                             Foreground="#23E7DB" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top">
                  <TextBlock Text="Base Runtime"
                             FontFamily="Bahnschrift SemiBold"
                             FontSize="38"
                             Foreground="#F2FBF9"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Margin="0,4,0,0"
                             Foreground="#23E7DB"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis">
                    <Run Text="// platform | base runtime | status " />
                    <Run Text="{Binding BaseRuntimeStatusLabel, Mode=OneWay}" />
                    <Run Text=" | windows wsl " />
                    <Run Text="{Binding WindowsWslStatusLabel, Mode=OneWay}" />
                  </TextBlock>
                </StackPanel>
              </Grid>

              <StackPanel Grid.Row="1"
                          Grid.Column="2"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Right"
                          Margin="0,0,0,0">
                <TextBlock Text="// MANAGE"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Right"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
                <Button Style="{StaticResource ManageLinkButtonStyle}"
                        Command="{Binding OpenGuideCommand}"
                        Content="Guide" />
                <Button Style="{StaticResource ManageLinkButtonStyle}"
                        Command="{Binding SetupWindowsWslCommand}"
                        Content="Windows WSL" />
                <Button Style="{StaticResource ManageLinkButtonStyle}"
                        Command="{Binding SetupBaseRuntimeCommand}"
                        Content="{Binding BaseRuntimeActionText}" />
                <Button Style="{StaticResource ManageLinkButtonStyle}"
                        Command="{Binding UninstallBaseRuntimeCommand}"
                        Content="Unregister" />
                <Button Style="{StaticResource ManageLinkButtonStyle}"
                        Command="{Binding ShowHomeCommand}"
                        Content="Home" />

              </StackPanel>

              <Border Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Margin="0"
                      Style="{StaticResource PanelBorderStyle}"
                      Padding="16"
                      Background="#0A1415"
                      VerticalAlignment="Stretch">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="// BASE RUNTIME GUIDE"
                             Style="{StaticResource MonoLabelStyle}"
                             Foreground="{StaticResource LimeBrush}" />
                  <ScrollViewer Grid.Row="1"
                                Margin="0,10,0,0"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                CanContentScroll="False">
                    <ScrollViewer.Resources>
                      <Style TargetType="ScrollBar"
                             BasedOn="{StaticResource PaneScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                      <TextBlock Foreground="#D8EAE6"
                                 FontWeight="SemiBold"
                                 FontSize="12"
                                 Text="Use this order: get Windows WSL ready, install the NymphsCore runtime, then add modules from their cards."
                                 TextWrapping="Wrap" />
                      <Grid Margin="0,10,0,14">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="01"
                                   Foreground="#97DF48"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Check Windows WSL"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Look at Current State. If Windows WSL says Ready, skip the setup button and install Base Runtime."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                      <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="02"
                                   Foreground="#23E7DB"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Set Up Windows WSL only if needed"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Use this when Windows WSL is missing or not ready. Approve any Windows prompt, restart if asked, then reopen Manager."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="46" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="03"
                                   Foreground="#D77CD1"
                                   FontFamily="Cascadia Mono"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="Install Base Runtime, then modules"
                                     Foreground="#F0FAF7"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="13" />
                          <TextBlock Margin="0,2,0,0"
                                     Text="Choose an install drive, then click Install Base Runtime. After that, install each module from its card."
                                     Foreground="#9AB8B4"
                                     FontSize="11"
                                     TextWrapping="Wrap" />
                          <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="14" />
                              <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding BaseRuntimeDriveSummary}"
                                         Foreground="#9AB8B4"
                                         FontSize="11"
                                         TextWrapping="Wrap" />
                              <TextBlock Margin="0,6,0,0"
                                         Text="{Binding BaseRuntimeInstallPath}"
                                         Foreground="#7FF7EF"
                                         FontFamily="Cascadia Mono"
                                         FontSize="11"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding BaseRuntimeDrives}"
                                      SelectedItem="{Binding SelectedBaseRuntimeDrive}"
                                      DisplayMemberPath="DisplayLabel"
                                      IsEnabled="{Binding CanChooseBaseRuntimeDrive}"
                                      VerticalAlignment="Center"
                                      MinWidth="280">
                              <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanChooseBaseRuntimeDrive}" Value="True">
                                      <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </ComboBox.Style>
                            </ComboBox>
                          </Grid>
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                  </ScrollViewer>
                </Grid>
              </Border>

	              <StackPanel Grid.Row="2"
	                          Grid.Column="0"
	                          Grid.ColumnSpan="2"
	                          Margin="0,12,0,0">
                <Border Margin="0,0,0,12"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16"
                        Background="#081314">
                  <StackPanel>
                    <TextBlock Text="// RUNTIME LOGS"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding BaseRuntimeOperationLabel}"
                               Foreground="#D8EAE6"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <ScrollViewer Margin="0,10,0,0"
                                  MaxHeight="210"
                                  VerticalScrollBarVisibility="Hidden">
                      <TextBlock Text="{Binding BaseRuntimeProgressText}"
                                 Foreground="#7FF7EF"
                                 FontFamily="Cascadia Mono"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </Grid>

          <Grid Visibility="{Binding IsSystemChecksPage, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="// SYSTEM CHECKS"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
              <TextBlock Margin="0,10,0,0"
                         Text="Detailed readiness checks for the shared WSL runtime, install targets, GPU support, and current platform state."
                         Foreground="#A2C0BC"
                         TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding SystemChecks}"
                            Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="16"
                            CornerRadius="8"
                            BorderBrush="#183435"
                            BorderThickness="1"
                            Background="#0A1415">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}"
                                     FontFamily="Segoe UI Semibold"
                                     FontSize="16"
                                     Foreground="#F0FAF7" />
                          <TextBlock Margin="0,8,0,0"
                                     Text="{Binding Description}"
                                     Foreground="#BCD2CE"
                                     FontSize="12"
                                     TextWrapping="Wrap" />
                          <TextBlock Margin="0,10,0,0"
                                     Text="{Binding Details}"
                                     Foreground="#8FAAA5"
                                     FontSize="11.5"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                MinWidth="78"
                                Background="{Binding StatusBadgeBackground}"
                                BorderBrush="#173739"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="9,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                          <TextBlock Text="{Binding StatusLabel}"
                                     Foreground="#F4FCFA"
                                     FontWeight="Bold"
                                     FontSize="11.5"
                                     TextAlignment="Center" />
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <Grid Visibility="{Binding IsLogsPage, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="{Binding ActualHeight, ElementName=MainContentScrollViewer}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <TextBlock Text="// LOG STREAM"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
            </Grid>
            <Border Grid.Row="1"
                      Margin="0,12,0,0"
                      Background="#081112"
                      BorderBrush="#173435"
                      BorderThickness="1"
                      Padding="14">
                <TextBox x:Name="UnifiedLogTextBox"
                         Text="{Binding UnifiedLogText, Mode=OneWay}"
                         TextChanged="UnifiedLogTextBox_TextChanged"
                         PreviewMouseDown="UnifiedLogTextBox_PreviewMouseDown"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         Foreground="#8FD7D0"
                         CaretBrush="#23E7DB"
                         SelectionBrush="#1B6568"
                         SelectionOpacity="0.95"
                         FontFamily="Consolas"
                         FontSize="11"
                         FontWeight="Light"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         Focusable="True"
                         IsTabStop="True"
                         Cursor="IBeam"
                         MinHeight="0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalScrollBarVisibility="Visible"
                         HorizontalScrollBarVisibility="Disabled">
                  <TextBox.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Copy"
                                Click="UnifiedLogCopyMenuItem_Click" />
                      <MenuItem Header="Select all"
                                Click="UnifiedLogSelectAllMenuItem_Click" />
                    </ContextMenu>
                  </TextBox.ContextMenu>
                  <TextBox.Resources>
                    <Style TargetType="ScrollBar"
                           BasedOn="{StaticResource LogScrollBarStyle}" />
                  </TextBox.Resources>
                </TextBox>
              </Border>
          </Grid>

          <Grid Visibility="{Binding IsGuidePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
              <TextBlock Text="// GUIDE"
                         Style="{StaticResource MonoLabelStyle}"
                         Foreground="{StaticResource LimeBrush}" />
              <TextBlock Margin="0,12,0,18"
                         Text="This shell keeps only core references here: general guidance, Manager README, footprint docs, and addon docs. Module-deep controls belong on module pages."
                         Foreground="#A2C0BC"
                         TextWrapping="Wrap" />

              <WrapPanel>
                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Core Guide"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the main public guide for the shared platform."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenGuideCommand}"
                            Content="Open Guide" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Manager README"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the current Manager README and implementation notes."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenReadmeCommand}"
                            Content="Open README" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Addon Guide"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the external addon documentation that sits outside the Nymph layer."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenAddonGuideCommand}"
                            Content="Open Addon Guide" />
                  </StackPanel>
                </Border>

                <Border Style="{StaticResource GuideCardBorderStyle}">
                  <StackPanel>
                    <TextBlock Text="Footprint"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="22"
                               Foreground="#F0FAF7" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Open the footprint notes for shared runtime expectations."
                               Foreground="#A2C0BC"
                               TextWrapping="Wrap" />
                    <Button Margin="0,18,0,0"
                            Style="{StaticResource ShellButtonStyle}"
                            Command="{Binding OpenFootprintCommand}"
                            Content="Open Footprint Doc" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </StackPanel>
          </Grid>

          <Grid Visibility="{Binding IsModulePage, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Height="{Binding ActualHeight, ElementName=MainContentScrollViewer}"
                  MinHeight="0"
                  Visibility="{Binding HasSelectedModule, Converter={StaticResource BoolToVisibilityConverter}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="0" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="138" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="64"
                        Height="64"
                        CornerRadius="16"
                        Background="#0A1717"
                        BorderBrush="{Binding DisplayedModule.AccentBrush}"
                        BorderThickness="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        ToolTip="Show or hide sidebar"
                        MouseLeftButtonUp="ModuleLogoCollapseButton_MouseLeftButtonUp">
                  <TextBlock Text="{Binding DisplayedModule.Monogram}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontFamily="Cascadia Mono"
                             FontSize="17"
                             FontWeight="Bold"
                             Foreground="{Binding DisplayedModule.AccentBrush}" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top">
                  <TextBlock Text="{Binding DisplayedModule.Name}"
                             FontFamily="Bahnschrift SemiBold"
                             FontSize="38"
                             Foreground="#F2FBF9"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Margin="0,4,0,0"
                             Foreground="#23E7DB"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis">
                    <Run Text="// " />
                    <Run Text="{Binding DisplayedModule.Category, Mode=OneWay}" />
                    <Run Text=" | " />
                    <Run Text="{Binding DisplayedModule.Kind, Mode=OneWay}" />
                    <Run Text=" | installed " />
                    <Run Text="{Binding DisplayedModule.VersionLabel, Mode=OneWay}" />
                    <Run Text=" | remote " />
                    <Run Text="{Binding DisplayedModule.RemoteVersionLabel, Mode=OneWay}" />
                    <Run Text=" | " />
                    <Hyperlink Command="{Binding OpenModuleSourceCommand}"
                               CommandParameter="{Binding DisplayedModule}"
                               Foreground="#97DF48"
                               TextDecorations="{x:Null}">
                      <Run Text="GitHub" />
                    </Hyperlink>
                  </TextBlock>
                </StackPanel>
              </Grid>

              <StackPanel Grid.Row="1"
                          Grid.Column="2"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Right"
                          Margin="0,0,0,0">
                <TextBlock Text="// MANAGE"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Right"
                           Style="{StaticResource MonoLabelStyle}"
                           Foreground="{StaticResource LimeBrush}" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding OpenGuideCommand}"
		                        Content="Guide" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding InstallModuleCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
		                        Content="Install" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding UpdateModuleCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
		                        Content="Update" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding RepairModuleCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
		                        Content="Repair" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding OpenModelCacheCommand}"
		                        Content="Model Cache" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding OpenModuleInstallPathCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
	                        Content="Directory" />
		                <Button Style="{StaticResource ManageLinkButtonStyle}"
		                        Command="{Binding UninstallModuleCommand}"
		                        CommandParameter="{Binding DisplayedModule}"
		                        Content="Uninstall" />
              </StackPanel>

              <Border Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Margin="0"
                      Style="{StaticResource PanelBorderStyle}"
                      Padding="16"
                      Background="#0A1415"
                      VerticalAlignment="Stretch">
                  <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="// DETAILS"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Text="{Binding ModuleActionFeedbackTitle}"
                               Foreground="#D8EAE6"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="2"
                                  Margin="0,8,0,0"
                                  VerticalAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
	                      <ScrollViewer.Resources>
	                        <Style TargetType="ScrollBar"
	                               BasedOn="{StaticResource PaneScrollBarStyle}" />
	                      </ScrollViewer.Resources>
                      <StackPanel>
                        <TextBlock Text="{Binding ModuleActionFeedbackDetail}"
                                   Foreground="#9AB8B4"
                                   FontSize="12"
                                   VerticalAlignment="Stretch"
                                   TextWrapping="Wrap" />
                        <StackPanel Margin="0,10,0,0"
                                    Visibility="{Binding DisplayedModule.HasManagerActionGroupLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                          <TextBlock Text="Source links:"
                                     Foreground="#D8EAE6"
                                     FontWeight="SemiBold"
                                     FontSize="12"
                                     Margin="0,0,0,3" />
                          <ItemsControl ItemsSource="{Binding DisplayedModule.ManagerActionGroupLinks}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="12">
                                  <Hyperlink Command="{Binding DataContext.OpenModuleActionLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding}"
                                             Foreground="#97DF48"
                                             TextDecorations="{x:Null}">
                                    <Run Text="{Binding Label, Mode=OneWay}" />
                                  </Hyperlink>
                                </TextBlock>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
	                  </Grid>
              </Border>

              <StackPanel Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="0,12,0,0">
                <Border Margin="0,0,0,12"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16"
                        Background="#081314"
                        Visibility="{Binding ShowModuleInstallFields, Converter={StaticResource BoolToVisibilityConverter}}">
                  <StackPanel>
                    <TextBlock Text="{Binding DisplayedModuleInstallOptionsTitle, StringFormat=// {0}}"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding DisplayedModuleInstallFields}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal"
                                      Margin="0,0,10,6"
                                      VerticalAlignment="Center">
                            <TextBlock Text="{Binding Label, StringFormat={}{0}:}"
                                       Foreground="#9AB8B4"
                                       FontFamily="Cascadia Mono"
                                       FontSize="10.5"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Width="145"
                                       Margin="0,0,7,0" />
                            <ComboBox ItemsSource="{Binding Options}"
                                      SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      TextSearch.TextPath="Label"
                                      Style="{StaticResource DarkComboBoxStyle}"
                                      Width="236"
                                      MinHeight="24"
                                      Padding="6,2">
                              <ComboBox.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding Label}"
                                             TextTrimming="CharacterEllipsis"
                                             ToolTip="{Binding Description}" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Margin="0,0,0,12"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="16"
                        Background="#081314"
                        Visibility="{Binding ShowModuleLogs, Converter={StaticResource BoolToVisibilityConverter}}">
                  <StackPanel>
                    <TextBlock Text="// MODULE LOGS"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding ModuleLogsTitle}"
                               Foreground="#D8EAE6"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <ScrollViewer Margin="0,10,0,0"
                                  MaxHeight="210"
                                  VerticalScrollBarVisibility="Hidden">
                      <TextBox Text="{Binding ModuleLogsDetail, Mode=OneWay}"
                               IsReadOnly="True"
                               BorderThickness="0"
                               Background="Transparent"
                               Foreground="#7FF7EF"
                               FontFamily="Cascadia Mono"
                               FontSize="11"
                               TextWrapping="Wrap"
                               AcceptsReturn="True"
                               VerticalScrollBarVisibility="Disabled"
                               HorizontalScrollBarVisibility="Disabled" />
	                    </ScrollViewer>
	                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding DisplayedModuleActionGroups}"
                              Visibility="{Binding ShowInstalledModuleActionGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,6">
                          <TextBlock Text="{Binding Title, StringFormat=// {0}}"
                                     Style="{StaticResource MonoLabelStyle}"
                                     Foreground="{StaticResource LimeBrush}"
                                     FontSize="13"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center" />
		                      </StackPanel>

                        <StackPanel>
                          <ItemsControl ItemsSource="{Binding SecretFields}"
                                        Visibility="{Binding HasSecretFields, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,10,8"
                                            VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Label, StringFormat={}{0}:}"
                                             Foreground="#9AB8B4"
                                             FontFamily="Cascadia Mono"
                                             FontSize="10.5"
                                             VerticalAlignment="Center"
                                             TextAlignment="Right"
                                             Width="145"
                                             Margin="0,0,7,0" />
                                  <Grid Width="426"
                                              Visibility="{Binding IsSecret, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                      <ColumnDefinition Width="300" />
                                      <ColumnDefinition Width="10" />
                                      <ColumnDefinition Width="116" />
                                    </Grid.ColumnDefinitions>
	                                    <PasswordBox Style="{StaticResource CompactSecretBoxStyle}"
	                                                 Width="300"
	                                                 PasswordChanged="ModuleActionSecretBox_PasswordChanged"
	                                                 ToolTip="Optional Hugging Face token. The Manager saves it for future model downloads."
	                                                 Visibility="{Binding ShowSecretInput, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Border Width="300"
                                            MinHeight="24"
                                            Padding="7,3"
                                            Background="#101B1D"
                                            BorderBrush="#284446"
                                            BorderThickness="1"
                                            Visibility="{Binding ShowSavedSecretMask, Converter={StaticResource BoolToVisibilityConverter}}">
                                      <TextBlock Text="{Binding SavedSecretMask}"
                                                 Foreground="#E4F2EF"
                                                 FontSize="11"
                                                 VerticalAlignment="Center" />
                                    </Border>
	                                    <Button Style="{StaticResource ContractLinkButtonStyle}"
	                                            Grid.Column="2"
	                                            Width="116"
	                                            Margin="0"
	                                            Command="{Binding DataContext.ClearModuleActionSecretCommand, RelativeSource={RelativeSource AncestorType=Window}}"
	                                            CommandParameter="{Binding}"
	                                            ToolTip="Remove the saved Hugging Face token from this PC"
	                                            Visibility="{Binding HasSavedSecret, Converter={StaticResource BoolToVisibilityConverter}}">
                                      <TextBlock Text="remove token"
                                                 Foreground="#23E7DB"
                                                 FontFamily="Cascadia Mono"
                                                 FontSize="10.5" />
                                    </Button>
                                  </Grid>
                                </StackPanel>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <WrapPanel>
                            <ItemsControl ItemsSource="{Binding OptionFields}"
                                          Visibility="{Binding HasOptionFields, Converter={StaticResource BoolToVisibilityConverter}}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <StackPanel Orientation="Horizontal"
                                              Margin="0,0,10,6"
                                              VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label, StringFormat={}{0}:}"
                                               Foreground="#9AB8B4"
                                               FontFamily="Cascadia Mono"
                                               FontSize="10.5"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Width="145"
                                               Margin="0,0,7,0" />
                                    <ComboBox ItemsSource="{Binding Options}"
                                              SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Value"
                                              TextSearch.TextPath="Label"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              Width="236"
                                              MinHeight="24"
                                              Padding="6,2">
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                          <TextBlock Text="{Binding Label}"
                                                     TextTrimming="CharacterEllipsis"
                                                     ToolTip="{Binding Description}" />
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                  </StackPanel>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          <Button Style="{StaticResource ModuleActionButtonStyle}"
                                  Width="180"
                                  Margin="0,0,10,6"
                                  Command="{Binding DataContext.RunModuleActionGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                            <TextBlock Text="{Binding SubmitLabel, StringFormat=// {0}}"
                                       Foreground="#23E7DB"
                                       FontFamily="Cascadia Mono"
                                       FontSize="12" />
                          </Button>
                          </WrapPanel>
                        </StackPanel>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,0,0,10"
	                             Text="// MODULE ACTIONS"
	                             Style="{StaticResource MonoLabelStyle}"
	                             Foreground="{StaticResource LimeBrush}"
                             Visibility="{Binding ShowInstalledModuleActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                  <ItemsControl ItemsSource="{Binding DisplayedModuleContractActions}"
                                Visibility="{Binding ShowInstalledModuleActions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Style="{StaticResource ModuleActionButtonStyle}"
                                Margin="0,0,10,10"
                                Command="{Binding DataContext.RunModuleActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                          <TextBlock Text="{Binding DisplayLabel, StringFormat=// {0}}"
                                     Foreground="#23E7DB"
                                     FontFamily="Cascadia Mono"
                                     FontSize="12" />
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <StackPanel Margin="0,8,0,0"
                              Visibility="{Binding ShowDevContract, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Margin="0,0,0,10"
                               Text="// DEV CONTRACT"
                               Style="{StaticResource MonoLabelStyle}"
                               Foreground="{StaticResource LimeBrush}" />
                    <ItemsControl ItemsSource="{Binding DisplayedModule.DevCapabilities}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource ModuleActionButtonStyle}"
                                  Margin="0,0,10,10"
                                  Command="{Binding DataContext.RunModuleDevActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                            <TextBlock Text="{Binding StringFormat=// {0}}"
                                       Foreground="#97DF48"
                                       FontFamily="Cascadia Mono"
                                       FontSize="12" />
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
              </StackPanel>

            </Grid>
          </Grid>
        </Grid>
      </ScrollViewer>

      <Grid Grid.Row="1"
            Grid.RowSpan="2"
            Margin="0"
            Visibility="{Binding IsModuleUiPage, Converter={StaticResource BoolToVisibilityConverter}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="0" />
          <ColumnDefinition Width="0" />
        </Grid.ColumnDefinitions>

        <wv2:WebView2 x:Name="ModuleUiBrowser"
                      Grid.Row="0"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0"
                      Loaded="ModuleUiBrowser_Loaded"
                      CoreWebView2InitializationCompleted="ModuleUiBrowser_CoreWebView2InitializationCompleted"
                      NavigationStarting="ModuleUiBrowser_NavigationStarting"
                      NavigationCompleted="ModuleUiBrowser_NavigationCompleted" />

        <WrapPanel Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,8,0,0">
          <TextBlock Text="//"
                     Margin="0,3,7,0"
                     Style="{StaticResource MonoLabelStyle}"
                     Foreground="{StaticResource LimeBrush}" />
          <ItemsControl ItemsSource="{Binding DisplayedModuleContractActions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource ContractLinkButtonStyle}"
                        Command="{Binding DataContext.RunModuleActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}">
                  <TextBlock Text="{Binding DisplayLabel}"
                             Foreground="#23E7DB"
                             FontFamily="Cascadia Mono"
                             FontSize="10.5" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Orientation="Horizontal"
                      Margin="7,0,0,0"
                      Visibility="{Binding ShowDevContract, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="dev:"
                       Margin="0,3,6,0"
                       Foreground="#97DF48"
                       FontFamily="Cascadia Mono"
                       FontSize="10.5" />
            <ItemsControl ItemsSource="{Binding DisplayedModule.DevCapabilities}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource ContractLinkButtonStyle}"
                          Command="{Binding DataContext.RunModuleDevActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}">
                    <TextBlock Text="{Binding}"
                               Foreground="#97DF48"
                               FontFamily="Cascadia Mono"
                               FontSize="10.5" />
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </WrapPanel>
      </Grid>

      <Border Grid.Row="2"
              Visibility="{Binding IsStandardContentPage, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="0,8,0,8"
              Padding="8,5"
              Background="#081314"
              BorderBrush="#173436"
              BorderThickness="1,1,1,0">
        <DockPanel LastChildFill="True">
          <TextBlock Text="{Binding DeveloperModeLabel}"
                     DockPanel.Dock="Right"
                     Margin="12,0,8,0"
                     Foreground="{Binding DeveloperModeBrush}"
                     FontFamily="Cascadia Mono"
                     FontSize="10.5"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding BottomStatusText}"
                     Foreground="#8FB2AD"
                     FontFamily="Cascadia Mono"
                     FontSize="10.5"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>
    </Grid>

	  </Grid>
	</Window>
