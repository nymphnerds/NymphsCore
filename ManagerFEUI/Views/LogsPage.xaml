<UserControl x:Class="ManagerFEUI.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:ManagerFEUI.Controls"
             Padding="24">
  <StackPanel>
    <Grid Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Live Logs" FontSize="20" FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource HeaderFont}"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="Clear" Style="{StaticResource NavButton}" Margin="0,0,8,0"
                Command="{Binding ClearLogsCommand}"/>
        <Button Content="Export" Style="{StaticResource NavButton}"/>
      </StackPanel>
    </Grid>

    <ctrl:LiveLogView LogLines="{Binding AllLogLines}" AutoScroll="True"/>
  </StackPanel>
</UserControl>