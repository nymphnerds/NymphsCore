<UserControl x:Class="ManagerFEUI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:ManagerFEUI.Controls"
             Padding="24">
  <StackPanel>
    <TextBlock Text="System Overview" FontSize="20" FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"
               FontFamily="{StaticResource HeaderFont}"/>

    <ItemsControl ItemsSource="{Binding MetricCards}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="3"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Padding="12">
            <ctrl:MetricCard Title="{Binding Title}"
                             Percentage="{Binding Percentage}"
                             DisplayValue="{Binding DisplayValue}"/>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimary}" Margin="0,24,0,12"
               FontFamily="{StaticResource HeaderFont}"/>

    <ctrl:LiveLogView LogLines="{Binding RecentLogLines}" Height="200"
                      AutoScroll="True"/>
  </StackPanel>
</UserControl>