<UserControl x:Class="ManagerFEUI.Views.PlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBlock Text="{Binding PlaceholderTitle}" FontSize="24" FontWeight="SemiBold"
               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"
               FontFamily="{StaticResource HeaderFont}"/>
    <TextBlock Text="{Binding PlaceholderSubtitle}" FontSize="14"
               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center"
               Margin="0,8,0,0"/>
  </StackPanel>
</UserControl>